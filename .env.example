# Anthropic key from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Gemini key from Google AI Studio: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-key-here

# Groq key from https://console.groq.com/keys
GROQ_API_KEY=your-groq-key-here

# Suppress verbose LiteLLM logs during experiments
LITELLM_LOG=ERROR

# Optional override for active provider (anthropic | gemini | groq)
ACTIVE_PROVIDER=gemini

# Reproducibility settings
EXPERIMENT_SEED=42
EXPERIMENT_TEMPERATURE=0.2

# Optional model override for Anthropic
ANTHROPIC_MODEL=claude-sonnet-4-6
