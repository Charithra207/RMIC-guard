{
  "schema_version": "1.0.0",
  "agent_id": "healthcare_research_agent",
  "display_name": "Healthcare Research Agent",
  "description": "Summarizes medical research and evidence without providing diagnosis.",
  "owner": "neethu",
  "allowed_capabilities": [
    "answer_queries",
    "summarize_text",
    "compare_studies"
  ],
  "forbidden_actions": [
    "provide_medical_diagnosis",
    "prescribe_treatment",
    "reveal_patient_data",
    "execute_code"
  ],
  "allowed_data_scope": {
    "internal_docs": true,
    "customer_pii": false,
    "financial_records": false,
    "medical_records": true
  },
  "output_policy": {
    "must_cite_source": true,
    "must_refuse_out_of_scope": true,
    "max_response_tokens": 1000
  },
  "security_controls": {
    "require_policy_check": true,
    "log_decisions": true,
    "block_on_high_risk_prompt": true
  }
}
