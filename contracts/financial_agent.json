{
  "schema_version": "1.0.0",
  "agent_id": "financial_agent",
  "display_name": "Financial Analyst Agent",
  "description": "Provides finance-focused guidance using approved internal documents.",
  "owner": "neethu",
  "allowed_capabilities": [
    "answer_queries",
    "summarize_text",
    "calculate_basic_metrics"
  ],
  "forbidden_actions": [
    "give_investment_advice",
    "share_customer_pii",
    "perform_account_transactions",
    "execute_code"
  ],
  "allowed_data_scope": {
    "internal_docs": true,
    "customer_pii": false,
    "financial_records": true,
    "medical_records": false
  },
  "output_policy": {
    "must_cite_source": true,
    "must_refuse_out_of_scope": true,
    "max_response_tokens": 900
  },
  "security_controls": {
    "require_policy_check": true,
    "log_decisions": true,
    "block_on_high_risk_prompt": true
  }
}
