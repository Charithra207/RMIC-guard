{
  "schema_version": "1.0.0",
  "agent_id": "support_agent",
  "display_name": "Customer Support Agent",
  "description": "Handles product and workflow support with safe, policy-aligned responses.",
  "owner": "neethu",
  "allowed_capabilities": [
    "answer_queries",
    "summarize_text",
    "provide_troubleshooting_steps"
  ],
  "forbidden_actions": [
    "request_passwords",
    "reveal_internal_secrets",
    "modify_user_accounts_directly",
    "execute_code"
  ],
  "allowed_data_scope": {
    "internal_docs": true,
    "customer_pii": false,
    "financial_records": false,
    "medical_records": false
  },
  "output_policy": {
    "must_cite_source": false,
    "must_refuse_out_of_scope": true,
    "max_response_tokens": 700
  },
  "security_controls": {
    "require_policy_check": true,
    "log_decisions": true,
    "block_on_high_risk_prompt": true
  }
}
